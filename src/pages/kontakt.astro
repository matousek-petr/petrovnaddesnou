---
import Base from '@/layouts/Base.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';

const contacts = [
  { role: 'Starosta', name: 'Bc. Radoslav Matoušek', phone: '+420 583 283 274', phone2: '+420 778 521 794', email: 'starosta@petrovnaddesnou.cz' },
  { role: 'Místostarostka', name: 'Lenka Václavská', phone: '+420 774 455 490', email: 'mistostarosta@petrovnaddesnou.cz' },
  { role: 'Referentka', name: 'Ivana Dítětová', phone: '+420 583 212 205', phone2: '+420 773 391 210', email: 'ivana.ditetova@petrovnaddesnou.cz' },
  { role: 'Referentka', name: 'Bc. Michaela Žáková', phone: '+420 583 283 275', email: 'michaela.zakova@petrovnaddesnou.cz' },
  { role: 'Referentka', name: 'Bc. Helena Faltusová', phone: '+420 583 285 310', phone2: '+420 778 440 695', email: 'helena.faltusova@petrovnaddesnou.cz' },
  { role: 'Referentka', name: 'Ing. Petra Šindlerová', phone: '+420 583 284 647', email: 'petra.sindlerova@petrovnaddesnou.cz' },
];
---

<Base title="Kontakt">
  <Header />
  <main id="main-content" class="flex-1">
    <div class="bg-forest-700 text-white py-10">
      <div class="max-w-6xl mx-auto px-4">
        <nav class="text-forest-200 text-sm mb-2">
          <a href="/" class="hover:text-white">Domů</a> / Kontakt
        </nav>
        <h1 class="text-3xl font-bold">Kontakt</h1>
      </div>
    </div>

    <div class="max-w-6xl mx-auto px-4 py-12 grid grid-cols-1 md:grid-cols-2 gap-10">

      <!-- Contact info -->
      <div class="space-y-8">
        <div>
          <h2 class="section-title">Obecní úřad</h2>
          <address class="not-italic text-gray-600 space-y-2 mt-3">
            <p class="flex items-start gap-2">
              <svg class="w-5 h-5 text-forest-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              Petrov nad Desnou 156<br/>788 16 Petrov nad Desnou
            </p>
            <p class="flex items-center gap-2">
              <svg class="w-5 h-5 text-forest-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <a href="tel:+420583284647" class="hover:text-forest-600 transition-colors">+420 583 284 647</a>
            </p>
            <p class="flex items-center gap-2">
              <svg class="w-5 h-5 text-forest-500 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <a href="mailto:podatelna@petrovnaddesnou.cz" class="hover:text-forest-600 transition-colors">podatelna@petrovnaddesnou.cz</a>
            </p>
          </address>
        </div>

        <!-- Hours -->
        <div class="card p-5">
          <h3 class="font-semibold text-gray-900 mb-3">Úřední hodiny</h3>
          <table class="text-sm w-full">
            <tbody class="divide-y divide-gray-100">
              {[
                ['Pondělí', '8:00 – 12:00', '13:00 – 17:00'],
                ['Úterý',   '8:00 – 12:00', '13:00 – 14:30'],
                ['Středa',  '8:00 – 12:00', '13:00 – 17:00'],
                ['Čtvrtek', '8:00 – 12:00', '13:00 – 14:30'],
              ].map(([day, am, pm]) => (
                <tr>
                  <td class="py-2 font-medium text-gray-700 w-28">{day}</td>
                  <td class="py-2 text-gray-500">{am}</td>
                  <td class="py-2 text-gray-500">{pm}</td>
                </tr>
              ))}
              <tr>
                <td class="py-2 text-gray-400 text-xs" colspan="3">
                  Mimo úřední hodiny po telefonické domluvě.
                </td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Staff -->
        <div>
          <h2 class="section-title">Zaměstnanci</h2>
          <div class="mt-3 space-y-3">
            {contacts.map((contact) => (
              <div class="card p-4">
                <p class="text-xs text-forest-600 font-semibold uppercase tracking-wide">{contact.role}</p>
                <p class="font-semibold text-gray-900 mt-0.5">{contact.name}</p>
                <div class="mt-2 space-y-1 text-sm text-gray-500">
                  <p>
                    <a href={`tel:${contact.phone.replace(/\s/g, '')}`} class="hover:text-forest-600 transition-colors">{contact.phone}</a>
                    {contact.phone2 && <span> · <a href={`tel:${contact.phone2.replace(/\s/g, '')}`} class="hover:text-forest-600 transition-colors">{contact.phone2}</a></span>}
                  </p>
                  <p><a href={`mailto:${contact.email}`} class="hover:text-forest-600 transition-colors">{contact.email}</a></p>
                </div>
              </div>
            ))}
          </div>
      <!-- Contact form -->
      <div>
        <h2 class="section-title">Napište nám</h2>
        <form action="https://formspree.io/f/mzbnozdb" method="POST" class="mt-3 space-y-4">
          <div>
            <label for="name" class="block font-medium text-gray-700 mb-1">Jméno *</label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              required 
              class="w-full px-3 py-2 border border-gray-300 rounded-lg hover:border-forest-400 focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-transparent"
              placeholder="Vaše jméno"
            />
          </div>

          <div>
            <label for="email" class="block font-medium text-gray-700 mb-1">Email *</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              required 
              class="w-full px-3 py-2 border border-gray-300 rounded-lg hover:border-forest-400 focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-transparent"
              placeholder="vase@email.cz"
            />
          </div>

          <div>
            <label for="subject" class="block font-medium text-gray-700 mb-1">Předmět *</label>
            <input 
              type="text" 
              id="subject" 
              name="subject" 
              required 
              class="w-full px-3 py-2 border border-gray-300 rounded-lg hover:border-forest-400 focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-transparent"
              placeholder="Předmět zprávy"
            />
          </div>

          <div>
            <label for="message" class="block font-medium text-gray-700 mb-1">Zpráva *</label>
            <textarea 
              id="message" 
              name="message" 
              required 
              rows="5"
              class="w-full px-3 py-2 border border-gray-300 rounded-lg hover:border-forest-400 focus:outline-none focus:ring-2 focus:ring-forest-500 focus:border-transparent resize-none"
              placeholder="Vaše zpráva..."
            ></textarea>
          </div>

          <button 
            type="submit"
            class="w-full bg-forest-600 hover:bg-forest-700 text-white font-semibold py-2.5 rounded-lg transition-colors duration-200"
          >
            ✉️ Odeslat zprávu
          </button>
          
          <p class="text-xs text-gray-500 mt-2">
            Vaše údaje se nebudou využívat k jiným účelům a nebudeme je předávat třetím stranám.
          </p>
        </form>
      </div>
    </div>
        <h2 class="section-title">Kde nás najdete</h2>
        <div class="mt-3 rounded-xl overflow-hidden border border-gray-200 shadow-sm h-80">
          <iframe
            src="https://www.openstreetmap.org/export/embed.html?bbox=17.035%2C49.986%2C17.095%2C50.046&layer=mapnik&marker=50.0163744%2C17.0648881"
            width="100%"
            height="100%"
            loading="lazy"
            title="Mapa – Obecní úřad Petrov nad Desnou"
            class="border-0"
          ></iframe>
        </div>
        <div class="flex items-center justify-between mt-2">
          <p class="text-xs text-gray-400">IČO: 72054433 · Nejsme plátci DPH · DS: c42pa2g</p>
          <a
            href="https://www.openstreetmap.org/?mlat=50.0163744&mlon=17.0648881#map=15/50.0163744/17.0648881"
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs text-forest-600 hover:text-forest-700 font-medium"
          >
            Otevřít ve větší mapě →
          </a>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Base>
