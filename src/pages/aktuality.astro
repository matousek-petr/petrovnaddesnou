---
import Base from '@/layouts/Base.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { getCollection } from 'astro:content';
import '@/styles/global.css';

// Načtení všech článků a seřazení podle data (nejnovější nejdřív)
const articles = (await getCollection('aktuality'))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const categoryColors: Record<string, string> = {
  'Oznámení': 'bg-blue-100 text-blue-700',
  'Akce': 'bg-amber-100 text-amber-700',
  'Doprava': 'bg-green-100 text-green-700',
  'Zastupitelstvo': 'bg-purple-100 text-purple-700',
  'Ostatní': 'bg-gray-100 text-gray-600',
};
---

<Base title="Aktuality">
  <Header />
  <main id="main-content" class="flex-1">
    <div class="bg-forest-700 text-white py-10">
      <div class="max-w-6xl mx-auto px-4">
        <nav class="text-forest-200 text-sm mb-2">
          <a href="/" class="hover:text-white">Domů</a> / Aktuality
        </nav>
        <h1 class="text-3xl font-bold">Aktuality</h1>
      </div>
    </div>

    <div class="max-w-6xl mx-auto px-4 py-12">
      <div class="max-w-3xl space-y-5">
        {articles.length > 0 ? (
          articles.map(({ slug, data }) => (
            <a href={`/aktuality/${slug}`} class="card block p-6 hover:border-forest-200">
              <div class="flex items-center gap-3 mb-2">
                <span class:list={['text-xs font-semibold px-2 py-0.5 rounded-full', categoryColors[data.category] ?? 'bg-gray-100 text-gray-600']}>
                  {data.category}
                </span>
                <time class="text-xs text-gray-400">
                  {new Intl.DateTimeFormat('cs-CZ', { year: 'numeric', month: '2-digit', day: '2-digit' }).format(data.pubDate)}
                </time>
              </div>
              <h2 class="font-semibold text-gray-900 text-lg mb-1">{data.title}</h2>
              <p class="text-sm text-gray-500 leading-relaxed">{data.description}</p>
            </a>
          ))
        ) : (
          <p class="text-gray-500 text-center py-8">Zatím žádné aktuality k dispozici.</p>
        )}
      </div>
    </div>
  </main>
  <Footer />
</Base>
