---
import Base from '@/layouts/Base.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import '@/styles/global.css';
---

<Base title="Stránka nenalezena" description="Požadovaná stránka nebyla nalezena.">
  <Header />
  <main class="flex-1 flex items-center justify-center">
    <div class="max-w-md mx-auto px-4 py-24 text-center">
      <p class="text-8xl font-extrabold text-forest-100 leading-none select-none">404</p>
      <h1 class="text-2xl font-bold text-gray-900 mt-2 mb-3">Stránka nenalezena</h1>
      <p class="text-gray-500 mb-8">
        Omlouváme se, hledaná stránka neexistuje nebo byla přesunuta.
      </p>
      <div class="flex flex-wrap gap-3 justify-center">
        <a href="/" class="btn-primary">Zpět na úvod</a>
        <a href="/kontakt" class="btn-secondary">Kontakt</a>
      </div>
    </div>
  </main>
  <Footer />
</Base>
