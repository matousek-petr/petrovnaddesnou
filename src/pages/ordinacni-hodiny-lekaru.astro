const sections = [
  {
    title: 'Jak stránku používat',
    content:
      'Tento přehled uvádí konkrétní ordinační hodiny jednotlivých lékařů a ambulancí v okolí obce. Hodiny se mohou měnit, proto je před návštěvou vhodné ověřit aktuální provoz telefonicky.',
  },
  {
    title: 'Pro koho je stránka určena',
