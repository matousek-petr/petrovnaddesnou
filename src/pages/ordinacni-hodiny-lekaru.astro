      'Najdete zde praktického lékaře pro dospělé, pediatra, gynekologii, ORL i rehabilitaci v širším okolí obce.',
  },
];
---

<Base title="Ordinační hodiny lékařů" description="Přehled ordinačních hodin lékařů a ambulancí v okolí Petrově nad Desnou.">
  <Header />
  <main id="main-content" class="flex-1">
    <div class="bg-forest-700 text-white py-10">
      <div class="max-w-6xl mx-auto px-4">
        <nav class="text-forest-200 text-sm mb-2">
          <a href="/" class="hover:text-white">Domů</a> / <a href="/zivot" class="hover:text-white">Život v obci</a> / Ordinační hodiny lékařů
        </nav>
        <h1 class="text-3xl font-bold">Ordinační hodiny lékařů</h1>
        <p class="text-forest-100 text-sm mt-2 max-w-2xl">
          Přehled zdravotních a návazných ordinací v okolí obce s odkazy na jejich oficiální stránky.
        </p>
      </div>
    </div>

    <div class="max-w-6xl mx-auto px-4 py-12 space-y-10">
      <section class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {sections.map((section) => (
          <div class="card p-5 md:p-6">
            <h2 class="font-semibold text-gray-900 mb-2">{section.title}</h2>
            <p class="text-sm text-gray-600 leading-relaxed">{section.content}</p>
          </div>
        ))}
      </section>

      <section>
        <div class="flex items-center justify-between gap-4 mb-4">
          <div>
            <h2 class="section-title mb-1">Ordinační hodiny</h2>
            <p class="section-subtitle">Konkrétní časy podle jednotlivých ordinací</p>
          </div>
          <a href="/kontakt" class="btn-secondary text-sm whitespace-nowrap">Kontakt na obec →</a>
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-2 gap-4">
          {doctorHours.map((doctor) => (
            <details class="group card overflow-hidden border border-gray-200">
              <summary class="cursor-pointer list-none p-5 md:p-6 flex items-start justify-between gap-4 hover:bg-gray-50 transition-colors">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wide text-forest-600 mb-1">Aktualizováno {doctor.updated}</p>
                  <h3 class="font-semibold text-gray-900 leading-snug text-lg">{doctor.title}</h3>
                  <p class="text-sm text-gray-500 mt-1 leading-relaxed">{doctor.address}</p>
                  <p class="text-sm text-gray-600 mt-1">Telefon: {doctor.phone}</p>
                </div>
                <div class="shrink-0 text-forest-600 group-open:rotate-180 transition-transform duration-200 mt-1">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
                  </svg>
                </div>
              </summary>

              <div class="px-5 md:px-6 pb-5 md:pb-6 pt-0 space-y-2 border-t border-gray-100">
                <p class="text-sm text-gray-500 mt-4 mb-3">Rozklikni pro časy ordinace.</p>
                {doctor.hours.map(([day, items]) => (
                  <div class="rounded-lg border border-gray-200 bg-gray-50 p-3">
                    <div class="flex flex-wrap items-start gap-2 justify-between">
                      <p class="font-semibold text-gray-900">{day}</p>
                    </div>
                    <ul class="mt-2 space-y-1 text-sm text-gray-600">
                      {items.map((item) => (
                        <li>{item}</li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </details>
          ))}
        </div>
      </section>

      <section class="card p-6 bg-forest-50 border-forest-100">
        <h2 class="font-semibold text-gray-900 mb-2">Poznámka</h2>
        <p class="text-sm text-gray-600 leading-relaxed">
          Pokud chceš, můžeme to ještě zkrátit do podoby jedné tabulky nebo rozdělit na jednotlivé kategorie podle typu péče.
        </p>
      </section>
    </div>
  </main>
  <Footer />
</Base>