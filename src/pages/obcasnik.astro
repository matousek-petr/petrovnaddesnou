---
import Base from '@/layouts/Base.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { getCollection } from 'astro:content';
import '@/styles/global.css';

const issues = (await getCollection('obcasnik'))
  .sort((a, b) => b.data.number - a.data.number);

function formatDate(date: Date) {
  return date.toLocaleDateString('cs-CZ', { year: 'numeric', month: 'long' });
}
---

<Base title="Občasník" description="Archiv čísel obecního zpravodaje Petrov nad Desnou.">
  <Header />
  <main id="main-content" class="flex-1">
    <div class="bg-forest-700 text-white py-10">
      <div class="max-w-6xl mx-auto px-4">
        <nav class="text-forest-200 text-sm mb-2">
          <a href="/" class="hover:text-white">Domů</a> / Občasník
        </nav>
        <h1 class="text-3xl font-bold">Občasník</h1>
        <p class="text-forest-100 text-sm mt-2">Obecní zpravodaj – archiv všech vydání</p>
      </div>
    </div>

    <div class="max-w-6xl mx-auto px-4 py-12">
      {issues.length === 0 ? (
        <p class="text-gray-500">Zatím nebyla přidána žádná čísla.</p>
      ) : (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {issues.map(({ slug, data }) => (
            <a href={`/obcasnik/${slug}`} class="card block p-6 hover:border-forest-200 group">
              <p class="text-xs font-semibold uppercase tracking-wide text-forest-600 mb-1">
                č. {data.number}
              </p>
              <h2 class="text-lg font-bold text-gray-900 group-hover:text-forest-700 leading-snug">
                {data.title}
              </h2>
              <p class="text-sm text-gray-500 mt-2">{formatDate(data.pubDate)}</p>
              <span class="inline-block mt-4 text-sm font-medium text-forest-600 group-hover:text-forest-800">
                Číst PDF →
              </span>
            </a>
          ))}
        </div>
      )}
    </div>
  </main>
  <Footer />
</Base>
