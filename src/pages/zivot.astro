---
import Base from '@/layouts/Base.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { getCollection } from 'astro:content';
import '@/styles/global.css';

// Načtení budoucích akcí (od dneška dál)
const today = new Date();
today.setHours(0, 0, 0, 0);

const allEvents = await getCollection('udalosti');
const upcomingEvents = allEvents
  .filter((e) => new Date(e.data.date) >= today)
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());

const featuredEvent = upcomingEvents.find((event) => event.data.posterImage) ?? upcomingEvents[0] ?? null;

const eventTypeColors: Record<string, string> = {
  'Kultura': 'bg-pink-100 text-pink-700',
  'Sport': 'bg-blue-100 text-blue-700',
  'Setkání': 'bg-green-100 text-green-700',
  'Administrativa': 'bg-orange-100 text-orange-700',
};

const associations = [
  { name: 'SDH Petrov nad Desnou', desc: 'Sbor dobrovolných hasičů', href: '#' },
  { name: 'TJ Sokol Petrov', desc: 'Tělovýchovná jednota', href: '#' },
  { name: 'Myslivecký spolek', desc: 'Ochrana přírody a myslivost', href: '#' },
  { name: 'Klub seniorů', desc: 'Aktivity pro starší spoluobčany', href: '#' },
];
---

<Base title="Život v obci">
  <Header />
  <main id="main-content" class="flex-1">
    <div class="bg-forest-700 text-white py-10">
      <div class="max-w-6xl mx-auto px-4">
        <nav class="text-forest-200 text-sm mb-2">
          <a href="/" class="hover:text-white">Domů</a> / Život v obci
        </nav>
        <h1 class="text-3xl font-bold">Život v obci</h1>
      </div>
    </div>

    <div class="max-w-6xl mx-auto px-4 py-12 space-y-14">

      <!-- Hřiště -->
      <section>
        <div class="card p-6 md:p-7 bg-forest-50 border-forest-100 flex flex-col md:flex-row md:items-center justify-between gap-5">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-forest-600 mb-2">Sportoviště</p>
            <h2 class="text-2xl font-bold text-gray-900">Rezervace víceúčelového hřiště</h2>
            <p class="text-sm text-gray-600 mt-2 max-w-2xl">
              Vyberte si den a hodinový slot mezi 9:00 a 20:00. Rezervační kalendář je připraven pro testování a funguje přímo na webu.
            </p>
          </div>
          <a href="/rezervace-hriste" class="btn-primary whitespace-nowrap">
            Otevřít kalendář →
          </a>
        </div>
      </section>

      <!-- Events -->
      <section id="akce">
        <h2 class="section-title">Nadcházející akce</h2>
        <p class="section-subtitle">Přehled plánovaných akcí v obci</p>
        {featuredEvent?.data.posterImage && (
          <a href="#akce" class="card mb-6 grid grid-cols-1 md:grid-cols-[280px_1fr] overflow-hidden hover:border-forest-200">
            <div class="bg-gray-100 min-h-64 md:min-h-full">
              <img
                src={featuredEvent.data.posterImage}
                alt={`Plakát akce ${featuredEvent.data.title}`}
                class="w-full h-full object-cover"
                loading="eager"
              />
            </div>
            <div class="p-5 md:p-6 flex flex-col justify-between gap-4">
              <div>
                <p class="text-xs font-semibold uppercase tracking-wide text-forest-600 mb-2">Plakát akce</p>
                <h3 class="text-2xl font-bold text-gray-900 mb-2">{featuredEvent.data.title}</h3>
                <p class="text-sm text-gray-600 leading-relaxed">{featuredEvent.data.description}</p>
              </div>
              <div class="flex flex-wrap gap-3 text-sm text-gray-500">
                <span>{new Intl.DateTimeFormat('cs-CZ', { day: '2-digit', month: '2-digit', year: 'numeric' }).format(featuredEvent.data.date)}</span>
                {featuredEvent.data.time && <span>· {featuredEvent.data.time}</span>}
                <span>· {featuredEvent.data.location}</span>
              </div>
            </div>
          </a>
        )}
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {upcomingEvents.length > 0 ? (
            upcomingEvents.map((event) => (
              <div class="card p-5 space-y-3">
                {event.data.posterImage && (
                  <div class="overflow-hidden rounded-lg bg-white aspect-[2/3] flex items-center justify-center p-2 border border-gray-100">
                    <img
                      src={event.data.posterImage}
                      alt={`Plakát akce ${event.data.title}`}
                      class="w-full h-full object-contain"
                      loading={event === featuredEvent ? 'eager' : 'lazy'}
                    />
                  </div>
                )}
                <div class="flex items-center gap-1.5 mb-3">
                  {event.data.eventType && (
                    <span class:list={['text-xs font-semibold px-2 py-0.5 rounded-full', eventTypeColors[event.data.eventType] ?? 'bg-gray-100 text-gray-600']}>
                      {event.data.eventType}
                    </span>
                  )}
                </div>
                <h3 class="font-semibold text-gray-900 mb-2">{event.data.title}</h3>
                <div class="space-y-1.5 text-sm text-gray-600">
                  <div class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                    </svg>
                    <time>{new Intl.DateTimeFormat('cs-CZ', { month: '2-digit', day: '2-digit' }).format(event.data.date)}</time>
                  </div>
                  {event.data.time && (
                    <div class="flex items-center gap-2">
                      <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                      {event.data.time}
                    </div>
                  )}
                  <div class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                    </svg>
                    {event.data.location}
                  </div>
                </div>
              </div>
            ))
          ) : (
            <div class="col-span-full text-center py-8 text-gray-500">
              Žádné nadcházející akce nejsou naplánované.
            </div>
          )}
        </div>
      </section>

      <!-- Associations -->
      <section id="spolky">
        <h2 class="section-title">Spolky a organizace</h2>
        <p class="section-subtitle">Aktivní spolkový život v obci</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {associations.map(({ name, desc, href }) => (
            <a href={href} class="card p-5 flex items-start gap-4 hover:border-forest-200">
              <div class="w-10 h-10 rounded-lg bg-forest-100 flex items-center justify-center text-forest-600 shrink-0">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">{name}</h3>
                <p class="text-sm text-gray-500 mt-0.5">{desc}</p>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- Waste & transport info -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <section id="odpad" class="card p-6">
          <h2 class="font-bold text-gray-900 mb-4 flex items-center gap-2">
            <span class="text-xl">🗑️</span> Odpad
          </h2>
          <dl class="text-sm space-y-3">
            {[
              ['Směsný odpad', 'Každé pondělí'],
              ['Plast',        'Každé 2 týdny v úterý'],
              ['Papír',        'Každé 2 týdny ve středu'],
              ['Sklo',         'Kontejnery u OÚ'],
              ['Bioodpad',     'Duben – říjen, každý týden'],
            ].map(([type, schedule]) => (
              <div class="flex justify-between gap-2 py-2 border-b border-gray-100 last:border-0">
                <dt class="text-gray-500">{type}</dt>
                <dd class="font-medium text-gray-900 text-right">{schedule}</dd>
              </div>
            ))}
          </dl>
        </section>

        <section id="doprava" class="card p-6">
          <h2 class="font-bold text-gray-900 mb-4 flex items-center gap-2">
            <span class="text-xl">🚌</span> Doprava
          </h2>
          <p class="text-sm text-gray-600 leading-relaxed mb-4">
            Obec je napojena na autobusovou linku Šumperk – Rapotín – Petrov nad Desnou.
            Spoje odjíždějí z autobusové zastávky u obecního úřadu.
          </p>
          <a
            href="https://idos.idnes.cz"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary text-sm"
          >
            Jízdní řády IDOS →
          </a>
        </section>
      </div>

      <section class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="card p-6">
          <h2 class="font-bold text-gray-900 mb-3 flex items-center gap-2">
            <span class="text-xl">🏟️</span> Víceúčelové hřiště
          </h2>
          <p class="text-sm text-gray-600 leading-relaxed mb-4">
            Pro občany a spolky připravujeme jednoduchý online kalendář rezervací s volnými hodinami od 9:00 do 20:00.
          </p>
          <a href="/rezervace-hriste" class="btn-secondary text-sm">
            Rezervovat hřiště →
          </a>
        </div>
      </section>

      <section>
        <div class="card p-6 md:p-7 bg-white border border-gray-200 flex flex-col md:flex-row md:items-center justify-between gap-5">
          <div>
            <p class="text-xs font-semibold uppercase tracking-wide text-forest-600 mb-2">Zdravotnictví</p>
            <h2 class="text-2xl font-bold text-gray-900">Ordinační hodiny lékařů</h2>
            <p class="text-sm text-gray-600 mt-2 max-w-2xl">
              Přehled ordinací a odkazů na lékaře a zdravotní služby v okolí obce.
            </p>
          </div>
          <a href="/ordinacni-hodiny-lekaru" class="btn-secondary whitespace-nowrap">
            Zobrazit přehled →
          </a>
        </div>
      </section>

    </div>
  </main>
  <Footer />
</Base>
