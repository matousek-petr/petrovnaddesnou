---
import Base from '@/layouts/Base.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { getCollection } from 'astro:content';
import '@/styles/global.css';

export async function getStaticPaths() {
  const aktuality = await getCollection('aktuality');
  return aktuality.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

interface Props {
  entry: any;
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const { title, description, pubDate, category, author } = entry.data;

const categoryColors: Record<string, string> = {
  'Oznámení': 'bg-blue-100 text-blue-700',
  'Akce': 'bg-amber-100 text-amber-700',
  'Doprava': 'bg-green-100 text-green-700',
  'Zastupitelstvo': 'bg-purple-100 text-purple-700',
  'Ostatní': 'bg-gray-100 text-gray-600',
};

const formattedDate = new Intl.DateTimeFormat('cs-CZ', {
  year: 'numeric',
  month: 'long',
  day: '2-digit',
}).format(pubDate);
---

<Base title={title} description={description} ogImage="/foto/uvodni-foto.jpg">
  <Header />
  <main id="main-content" class="flex-1">
    <!-- Hero section -->
    <div class="bg-forest-700 text-white py-10">
      <div class="max-w-6xl mx-auto px-4">
        <nav class="text-forest-200 text-sm mb-3">
          <a href="/" class="hover:text-white">Domů</a> / <a href="/aktuality" class="hover:text-white">Aktuality</a> / {title}
        </nav>
        <div class="flex items-center gap-3 mb-4">
          <span class:list={['text-xs font-semibold px-2 py-0.5 rounded-full', categoryColors[category] ?? 'bg-gray-200 text-gray-700']}>
            {category}
          </span>
          {author && <span class="text-sm text-forest-200">od {author}</span>}
        </div>
        <h1 class="text-4xl font-bold mb-2">{title}</h1>
        <time class="text-forest-100 text-sm">{formattedDate}</time>
      </div>
    </div>

    <!-- Content -->
    <div class="max-w-6xl mx-auto px-4 py-12 grid grid-cols-1 lg:grid-cols-3 gap-10">
      <article class="lg:col-span-2 prose prose-gray max-w-none">
        <Content />
      </article>

      <!-- Sidebar -->
      <aside class="space-y-4">
        <div class="card p-5">
          <h3 class="font-semibold text-gray-900 mb-4">Informace</h3>
          <dl class="text-sm space-y-3">
            <div>
              <dt class="font-medium text-gray-600">Kategorie</dt>
              <dd class="text-gray-900">{category}</dd>
            </div>
            <div>
              <dt class="font-medium text-gray-600">Zveřejněno</dt>
              <dd class="text-gray-900">{formattedDate}</dd>
            </div>
            {author && (
              <div>
                <dt class="font-medium text-gray-600">Autor</dt>
                <dd class="text-gray-900">{author}</dd>
              </div>
            )}
          </dl>
        </div>

        <!-- Related articles -->
        <div class="card p-5">
          <h3 class="font-semibold text-gray-900 mb-4">Zpět</h3>
          <a href="/aktuality" class="inline-flex items-center gap-2 text-forest-600 hover:text-forest-700 font-medium text-sm">
            ← Všechny aktuality
          </a>
        </div>
      </aside>
    </div>
  </main>
  <Footer />
</Base>
