---
import Base from '@/layouts/Base.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { getCollection } from 'astro:content';
import '@/styles/global.css';

// Načtení a seřazení dokumentů (nejnovější nejdřív, archivované poslední)
const documents = (await getCollection('uredni_deska'))
  .sort((a, b) => {
    if (a.data.isArchived === b.data.isArchived) {
      return new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime();
    }
    return a.data.isArchived ? 1 : -1;
  });

  // Base URL for external Úřední deska host (can be configured via PUBLIC_UDE_BASE_URL)
  const UDE_BASE = import.meta.env.PUBLIC_UDE_BASE_URL || 'https://ude.ginis.cloud/petrov-nad-desnou';

const categoryColors: Record<string, string> = {
  'Vyhláška': 'bg-red-100 text-red-700',
  'Úřední oznámení': 'bg-blue-100 text-blue-700',
  'Zápis ze zasedání': 'bg-purple-100 text-purple-700',
  'Výběrové řízení': 'bg-orange-100 text-orange-700',
};
---

<Base title="Úřední deska">
  <Header />
  <main id="main-content" class="flex-1">
    <div class="bg-forest-700 text-white py-10">
      <div class="max-w-6xl mx-auto px-4">
        <nav class="text-forest-200 text-sm mb-2">
          <a href="/" class="hover:text-white">Domů</a> / Úřední deska
        </nav>
        <h1 class="text-3xl font-bold">Úřední deska</h1>
        <p class="text-forest-200 text-sm mt-2">Vyhlášky, oznámení a oficiální dokumenty obce</p>
      </div>
    </div>

    <div class="max-w-6xl mx-auto px-4 py-12">
      {documents.length > 0 ? (
        <div class="space-y-3">
          {documents.map((doc) => (
            <div class:list={['card p-5 border-l-4', doc.data.isArchived ? 'border-l-gray-300 opacity-60' : 'border-l-forest-600']}>
              <div class="flex items-center justify-between gap-4">
                <div class="flex-1">
                  <div class="flex items-center gap-2 mb-2">
                    <span class:list={['text-xs font-semibold px-2 py-0.5 rounded-full', categoryColors[doc.data.category] ?? 'bg-gray-100 text-gray-600']}>
                      {doc.data.category}
                    </span>
                    {doc.data.isArchived && (
                      <span class="text-xs px-2 py-0.5 rounded-full bg-gray-200 text-gray-600 font-medium">Archivováno</span>
                    )}
                  </div>
                  <h2 class="font-semibold text-gray-900">{doc.data.title}</h2>
                  <time class="text-xs text-gray-400 mt-1">
                    {new Intl.DateTimeFormat('cs-CZ', { year: 'numeric', month: '2-digit', day: '2-digit' }).format(doc.data.pubDate)}
                  </time>
                </div>
                {doc.data.fileUrl && (
                  <a
                    href={doc.data.fileUrl?.startsWith('/') ? `${UDE_BASE}${doc.data.fileUrl}` : doc.data.fileUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="shrink-0 inline-flex items-center gap-1 bg-forest-50 text-forest-600 hover:bg-forest-100 px-3 py-2 rounded-lg font-medium text-sm transition-colors"
                  >
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                    </svg>
                    Stáhnout
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-gray-500 text-center py-8">Na úřední desce nejsou žádné dokumenty.</p>
      )}
    </div>
  </main>
  <Footer />
</Base>
