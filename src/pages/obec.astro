---
import Base from '@/layouts/Base.astro';
import Header from '@/components/Header.astro';
import Footer from '@/components/Footer.astro';
import { getEntry } from 'astro:content';
import '@/styles/global.css';

const obciPage = await getEntry('stranky', 'o-obci');
const { Content } = await obciPage.render();
const k = (await getEntry('nastaveni', 'kontakt')).data;
---

<Base title="O obci">
  <Header />
  <main id="main-content" class="flex-1">
    <div class="bg-forest-700 text-white py-10">
      <div class="max-w-6xl mx-auto px-4">
        <nav class="text-forest-200 text-sm mb-2">
          <a href="/" class="hover:text-white">Domů</a> / O obci
        </nav>
        <h1 class="text-3xl font-bold">O obci</h1>
      </div>
    </div>

    <div class="max-w-6xl mx-auto px-4 py-12 grid grid-cols-1 lg:grid-cols-3 gap-10">

      <!-- Main content -->
      <article class="lg:col-span-2 prose prose-gray max-w-none prose-headings:font-bold prose-h2:text-2xl prose-h2:mt-8 prose-p:text-gray-600 prose-p:leading-relaxed prose-li:text-gray-600">
        <Content />
      </article>

      <!-- Stats sidebar -->
      <aside class="space-y-4">
        <div class="card p-5">
          <h3 class="font-semibold text-gray-900 mb-4">Základní informace</h3>
          <dl class="text-sm space-y-3">
            {[
              ['Počet obyvatel', '~ 1 273 (1999)'],
              ['Nadmořská výška', '365 m n. m.'],
              ['Nejvyšší bod', 'Petrovský vrch 790 m'],
              ['Kraj', 'Olomoucký'],
              ['Okres', 'Šumperk'],
              ['PSČ', k.city.split(' ')[0]],
              ['IČO', k.ico],
              ['Datová schránka', k.ds],
            ].map(([label, value]) => (
              <div class="flex justify-between gap-2">
                <dt class="text-gray-500">{label}</dt>
                <dd class="font-medium text-gray-900 text-right">{value}</dd>
              </div>
            ))}
          </dl>
        </div>

        <div class="card p-5">
          <h3 class="font-semibold text-gray-900 mb-3">Symboly obce</h3>
          <div class="grid grid-cols-2 gap-3">
            <div class="bg-gray-50 rounded-lg p-4 flex flex-col items-center text-center">
              <img src="/foto/znak.png" alt="Znak obce Petrov nad Desnou" class="h-16 object-contain mb-2" />
              <span class="text-xs text-gray-500">Znak obce</span>
            </div>
            <div class="bg-gray-50 rounded-lg p-4 flex flex-col items-center text-center">
              <img src="/foto/vlajka.jpg" alt="Vlajka obce Petrov nad Desnou" class="h-12 object-contain mb-2" />
              <span class="text-xs text-gray-500">Vlajka obce</span>
            </div>
          </div>
        </div>
      </aside>
    </div>

    <!-- Photo gallery -->
    <div class="max-w-6xl mx-auto px-4 pb-12">
      <h2 class="text-xl font-bold text-gray-900 mb-4">Fotogalerie</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        <div class="rounded-xl overflow-hidden h-48 shadow-sm col-span-2 sm:col-span-1">
          <img src="/foto/panorama.jpg" alt="Panorama obce s hřebenem Jeseníků" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" loading="lazy" />
        </div>
        <div class="rounded-xl overflow-hidden h-48 shadow-sm">
          <img src="/foto/obec3.jpg" alt="Pohled na Petrov nad Desnou" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" loading="lazy" />
        </div>
        <div class="rounded-xl overflow-hidden h-48 shadow-sm">
          <img src="/foto/kapli-rocha.jpg" alt="Kaplička svatého Rocha" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" loading="lazy" />
        </div>
        <div class="rounded-xl overflow-hidden h-48 shadow-sm">
          <img src="/foto/obec1.jpg" alt="Pohled na obec" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" loading="lazy" />
        </div>
        <div class="rounded-xl overflow-hidden h-48 shadow-sm">
          <img src="/foto/kapli-ulice.jpg" alt="Kaplička u Petrovské ulice" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" loading="lazy" />
        </div>
        <div class="rounded-xl overflow-hidden h-48 shadow-sm">
          <img src="/foto/historicky-pohled.jpg" alt="Historický pohled na Petrov nad Desnou (1904)" class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" loading="lazy" />
        </div>
      </div>
      <p class="text-xs text-gray-400 mt-2">Zdroje: Wikimedia Commons (CC) · petrovnaddesnou.cz</p>
    </div>
  </main>
  <Footer />
</Base>
