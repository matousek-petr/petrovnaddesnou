---
import CookieBanner from '@/components/CookieBanner.astro';
import BackToTop from '@/components/BackToTop.astro';

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}
const {
  title,
  description = 'Oficiální webové stránky obce Petrov nad Desnou v Olomouckém kraji.',
  ogImage = '/foto/uvodni-foto.jpg',
} = Astro.props;

const siteUrl = 'https://www.petrovnaddesnou.cz';
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL(ogImage, siteUrl).href;
const fullTitle = title === 'Úvodní stránka' ? 'Petrov nad Desnou' : `${title} | Petrov nad Desnou`;
---
<!doctype html>
<html lang="cs">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:site_name"   content="Petrov nad Desnou" />
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url"         content={canonicalUrl} />
    <meta property="og:image"       content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:locale"      content="cs_CZ" />

    <!-- Twitter / X card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImageUrl} />
  </head>
  <body class="min-h-screen flex flex-col">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-forest-700 focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:font-semibold focus:text-sm"
    >
      Přejít na obsah
    </a>
    <slot />
    <BackToTop />
    <CookieBanner />
  </body>
</html>
