---
---
<footer class="bg-gray-900 text-gray-300 mt-auto">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      <!-- Brand -->
      <div>
        <div class="flex items-center gap-3 mb-4">
          <img src="/foto/znak.png" alt="Znak obce Petrov nad Desnou" class="w-9 h-9 object-contain shrink-0" />
          <div>
            <div class="font-bold text-white text-sm">Petrov nad Desnou</div>
            <div class="text-xs text-gray-400">Obec</div>
          </div>
        </div>
        <p class="text-sm leading-relaxed text-gray-400">
          Malá obec v Olomouckém kraji v podhůří Hrubého Jeseníku, na řece Desné.
        </p>
      </div>

      <!-- Quick links -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4 uppercase tracking-wide">Rychlé odkazy</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/uredni-deska" class="hover:text-white transition-colors">Úřední deska</a></li>
          <li><a href="/aktuality" class="hover:text-white transition-colors">Aktuality</a></li>
          <li><a href="/urad" class="hover:text-white transition-colors">Obecní úřad</a></li>
          <li><a href="/zivot" class="hover:text-white transition-colors">Život v obci</a></li>
          <li><a href="/kontakt" class="hover:text-white transition-colors">Kontakt</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold text-sm mb-4 uppercase tracking-wide">Kontakt</h3>
        <address class="not-italic text-sm space-y-2 text-gray-400">
          <p>Petrov nad Desnou 156<br/>788 16 Petrov nad Desnou</p>
          <p>
            <a href="tel:+420583284647" class="hover:text-white transition-colors">+420 583 284 647</a>
          </p>
          <p>
            <a href="mailto:podatelna@petrovnaddesnou.cz" class="hover:text-white transition-colors">podatelna@petrovnaddesnou.cz</a>
          </p>
        </address>
        <a
          href="https://www.facebook.com/petrovnaddesnou"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 mt-4 text-sm text-gray-400 hover:text-white transition-colors"
        >
          <svg class="w-4 h-4 fill-current" viewBox="0 0 24 24">
            <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.236 2.686.236v2.97h-1.513c-1.491 0-1.956.93-1.956 1.886v2.271h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
          </svg>
          Facebook
        </a>
      </div>
    </div>

    <div class="border-t border-gray-800 mt-10 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-gray-500">
      <p>© {new Date().getFullYear()} Obec Petrov nad Desnou. Všechna práva vyhrazena.</p>
      <p>
        <a href="https://www.olomoucky-kraj.cz" target="_blank" rel="noopener noreferrer" class="hover:text-gray-300 transition-colors">Olomoucký kraj</a>
        {' · '}
        <a href="https://www.sumperk.cz" target="_blank" rel="noopener noreferrer" class="hover:text-gray-300 transition-colors">Šumperk</a>
      </p>
    </div>
  </div>
</footer>
